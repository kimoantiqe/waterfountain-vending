<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background2"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!--
    LAYOUT STRATEGY (Phase A: 3-phase scan-reminder → advertiser reveal → drop):
    - RipplePondView sits at the bottom of the z-stack, full screen, so its
      ripples can travel past the visible logo without being clipped.
      clipChildren / clipToPadding disabled on every ancestor.
    - Phase 1 surface (phase1Container, centered): WF logo (bobbing) + the
      "Scan QR" reminder. The disc / ripples / progress text are NOT shown
      in Phase 1 — anticipation begins at the Phase 1→2 reveal.
    - Phase 2/3 surface (the centered LinearLayout below): progressText →
      disc (ringContainer + logoImage) → centerMessage → completionText.
      All start alpha=0 and fade in at the Phase 1→2 transition.
    - centerMessage shows the advertiser's animationMessage during Phase 2
      (blank if none was supplied — see VendingAnimationActivity).
    - No chip, no pip row, no post-vend billboard — the brand IS the disc +
      message. Anything else competes with it.
    -->

    <!-- Ripple pond (z=0) — additive layer behind all other content. -->
    <com.waterfountainmachine.app.ui.views.RipplePondView
        android:id="@+id/ripplePond"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Main Content - EXACT COPY of MainActivity structure -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="40dp"
        android:paddingTop="20dp"
        android:paddingBottom="40dp"
        android:gravity="center"
        android:clipChildren="false"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Progress Text - positioned ON TOP -->
            <TextView
                android:id="@+id/progressText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your water is on the way!"
                android:textSize="64sp"
                android:textColor="#555555"
                android:fontFamily="@font/gilroy"
                android:gravity="center"
                android:alpha="0"
                android:maxWidth="900dp"
                android:layout_marginBottom="60dp"
                android:letterSpacing="0.02"/>

            <!-- Disc container: the logo sits at a sensible kiosk-tablet
                 size (~540dp) and the ringContainer gives the ripple pond
                 a generous launch radius around it. Both clipChildren=false
                 so ripples can travel past container bounds. -->
            <FrameLayout
                android:id="@+id/ringContainer"
                android:layout_width="640dp"
                android:layout_height="640dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <ImageView
                    android:id="@+id/logoImage"
                    android:layout_width="540dp"
                    android:layout_height="540dp"
                    android:src="@drawable/logo"
                    android:contentDescription="@string/waterfountain_logo"
                    android:scaleType="fitCenter"
                    android:layout_gravity="center"
                    android:alpha="0"/>

            </FrameLayout>

            <!-- Center message — advertiser's animationMessage shown below
                 the disc during Phase 2. Stays hidden during Phase 1;
                 fades in at the Phase 1→2 transition alongside the
                 advertiser logo reveal. Blank if no animationMessage was
                 supplied (revealCenterMessage no-ops in that case) —
                 keeps the surface clean for unbranded vends. -->
            <TextView
                android:id="@+id/centerMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="42sp"
                android:textColor="#FF1F3242"
                android:fontFamily="@font/gilroy"
                android:gravity="center"
                android:maxWidth="1100dp"
                android:lineHeight="54sp"
                android:letterSpacing="0.02"
                android:layout_marginTop="36dp"
                android:alpha="0"/>

            <!-- Completion Text - positioned BELOW ring -->
            <TextView
                android:id="@+id/completionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your water is ready!"
                android:textSize="68sp"
                android:textColor="#555555"
                android:fontFamily="@font/gilroy"
                android:gravity="center"
                android:alpha="0"
                android:maxWidth="900dp"
                android:layout_marginTop="60dp"
                android:letterSpacing="0.02"/>

        </LinearLayout>

    </LinearLayout>


    <!-- Phase 1 surface — WF logo (bobbing) above the centered "Scan QR"
         reminder. Fades in at activity start, fades out at the Phase 1→2
         transition. Re-uses reminderIcon + statusText IDs the activity
         already references; the previously bottom-pinned QR section was
         replaced by this centered stack. -->
    <LinearLayout
        android:id="@+id/phase1Container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- WF logo — Phase 1 brand mark. Bobs up/down via a Y-translation
             loop started by VendingAnimationActivity.startWfLogoBob().
             Separate from logoImage (the disc center) so the bob doesn't
             fight the disc's Phase 2 reveal scale/alpha animation. -->
        <ImageView
            android:id="@+id/wfLogoPhase1"
            android:layout_width="380dp"
            android:layout_height="380dp"
            android:src="@drawable/logo"
            android:contentDescription="@string/waterfountain_logo"
            android:scaleType="fitCenter"
            android:alpha="0"
            android:layout_marginBottom="48dp"/>

        <!-- Reminder Icon (centered Phase 1, was bottom-pinned). -->
        <ImageView
            android:id="@+id/reminderIcon"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:src="@drawable/reminder"
            android:contentDescription="Reminder icon"
            android:scaleType="fitCenter"
            android:alpha="0"
            android:layout_marginBottom="16dp"/>

        <!-- QR scan reminder text (centered Phase 1, was bottom-pinned). -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scan the QR\non the back of the can\nto keep our waters free!"
            android:textSize="42sp"
            android:textColor="#555555"
            android:fontFamily="@font/gilroy"
            android:gravity="center"
            android:alpha="0"
            android:lineHeight="52sp"
            android:maxWidth="900dp"/>

    </LinearLayout>

    <!-- Konfetti for celebration -->
    <nl.dionsegijn.konfetti.xml.KonfettiView
        android:id="@+id/konfettiView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Pickup Reminder Panel (initially hidden) -->
    <LinearLayout
        android:id="@+id/pickupReminderPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="80dp"
        android:orientation="vertical"
        android:gravity="center"
        android:alpha="0"
        android:translationY="50dp"
        android:visibility="gone">

        <!-- Animated Chevrons Container -->
        <LinearLayout
            android:id="@+id/chevronsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/chevron1"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_chevron_down"
                android:contentDescription="Pickup indicator"
                android:layout_marginEnd="8dp"
                app:tint="#555555"/>

            <ImageView
                android:id="@+id/chevron2"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_chevron_down"
                android:contentDescription="Pickup indicator"
                android:layout_marginEnd="8dp"
                app:tint="#555555"/>

            <ImageView
                android:id="@+id/chevron3"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_chevron_down"
                android:contentDescription="Pickup indicator"
                app:tint="#555555"/>

        </LinearLayout>

        <!-- Shimmer overlay for purple accent effect -->
        <View
            android:id="@+id/shimmerOverlay"
            android:layout_width="160dp"
            android:layout_height="48dp"
            android:layout_marginTop="-64dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/shimmer_gradient"
            android:alpha="0"/>

        <!-- Primary Text -->
        <TextView
            android:id="@+id/pickupPrimaryText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Check the pickup door below"
            android:textSize="44sp"
            android:textColor="#555555"
            android:fontFamily="@font/gilroy"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <!-- Secondary Text -->
        <TextView
            android:id="@+id/pickupSecondaryText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lift it upwards!"
            android:textSize="32sp"
            android:textColor="#555555"
            android:alpha="0.7"
            android:fontFamily="@font/gilroy"
            android:gravity="center"
            android:lineHeight="40sp"/>

    </LinearLayout>

</FrameLayout>
