<?xml version="1.0" encoding="utf-8"?>
<!--
  Neumorphic surface background. Radial gradient: lightly-tinted center
  (#F2F4F8) → darker neumorphic gray (#C8CFDB) corners. The corner color
  matches RipplePondView's DEFAULT_FILL_COLOR so ripples blend into the
  perimeter as proper "shadows on a surface" rather than visible blobs.

  Applied to every kiosk-facing activity (main, pin, sms, sms_verify,
  error, vending_animation) so the surface reads consistently across
  the flow.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="radial"
        android:gradientRadius="120%p"
        android:centerX="0.5"
        android:centerY="0.5"
        android:startColor="#FFF2F4F8"
        android:endColor="#FFC8CFDB"/>
</shape>
